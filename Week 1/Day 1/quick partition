#include<bits/stdc++.h>
using namespace std;

int partition (int arr[], int start, int end)
{
    int p = arr[start];
    int count = 0;

 
    for (int i = start+1; i <= end; i++)
    {
        if (arr[i] <= p)
        {
            count++;
        }
    }

    int p_index = start + count;
    swap(arr[p_index], arr[start]);

    int i = start, j = end;

    while (i < p_index && j > p_index)
    {
        while (arr[i] < p)
        {
            i++;
        }

        while (arr[j] > p)
        {
            j--;
        }

        if (i < p_index && j > p_index)
        {
            swap(arr[i], arr[j]);
            i++;
            j--;
        }
    }

    return p_index;
}

int main()
{
    int n;
    cin >> n;

    int arr[n];

    for (int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    // Only ONE partition call
    partition(arr, 0, n-1);

    // Print result
    for (int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }

    return 0;
}
